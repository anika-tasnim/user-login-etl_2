(* converting the sessoion times to seconds and storing in a new table. *)

from pyspark.sql.functions import split, col

# Read cleaned table from Phase 1
df = spark.table("usr_activity_cleaned_data")

# Convert HH:MM:SS to seconds
df_session = (
    df.withColumn(
        "session_seconds",
        split(col("sessionDuration"), ":")[0].cast("int") * 3600 +
        split(col("sessionDuration"), ":")[1].cast("int") * 60 +
        split(col("sessionDuration"), ":")[2].cast("int")
    )
)
df_session.select("userid", "sessionDuration", "session_seconds").write.mode("error").saveAsTable("usr_activity_session_data")


(* Show spark tables *)
spark.sql("SHOW TABLES").show()

(* Describe the new table. *)
spark.sql("DESCRIBE TABLE usr_activity_session_data").show(truncate=False)
